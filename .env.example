# EmberHoneypot — Environment Variables
# Copy to .env and fill in real values before starting the server.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# SONAR (Perplexity) — Load-bearing live threat intelligence
# ---------------------------------------------------------------------------
# Perplexity API key for Sonar real-time threat enrichment.
# Used by SonarIntelligenceClient in intel/sonar_enrichment.py to:
#   - Look up current CVEs associated with observed attacker TTPs
#   - Identify active threat actor campaigns using captured techniques
#   - Enrich attacker profiles with live-web context
# Without this, TTP enrichment falls back to static pattern matching only.
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key-here

# ---------------------------------------------------------------------------
# HONEYPOT INTEGRATION
# ---------------------------------------------------------------------------
# EmberArmor integration (for forwarding events to the enforcement layer)
INTEGRATION_AUTH_URL=http://localhost:8000/v1/auth
INTEGRATION_AUDIT_URL=http://localhost:8000/v1/audit
INTEGRATION_API_KEY=your-ember-armor-api-key-here

# Centuria swarm endpoint (optional — for 39-agent coordination)
CENTURIA_ENDPOINT=http://localhost:9000

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
DEBUG=false
LOG_LEVEL=INFO
